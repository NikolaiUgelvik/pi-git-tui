{
  "name": "pi-git",
  "version": "0.1.0",
  "description": "Pi extension that adds an interactive /diff git diff and commit viewer.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "git",
    "diff"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "format": "biome check --write .",
    "lint": "biome check .",
    "check": "biome ci . && npm run typecheck && npm test && npm run fallow",
    "test": "sh -c 'rm -rf .tmp-tests && tsc --noEmit false --outDir .tmp-tests --rootDir . && node --test .tmp-tests/tests/*.test.js; status=$?; rm -rf .tmp-tests; exit $status'",
    "fallow": "fallow --ci --fail-on-issues",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^24.0.0",
    "fallow": "^2.88.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.0"
  }
}
