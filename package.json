{
  "name": "pi-git",
  "version": "0.1.0",
  "description": "Pi extension that adds an interactive /diff git diff and commit viewer.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "git",
    "diff"
  ],
  "license": "MIT",
  "files": [
    "extensions",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
